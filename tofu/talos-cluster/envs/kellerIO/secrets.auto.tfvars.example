# Copy to secrets.auto.tfvars and fill in real values (file is gitignored).
# Or use SOPS: see secrets.enc.yaml.example and `just secrets-encrypt`.

proxmox_api_token = "user@pam!tokenid=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Forgejo token/password with read access to the keller.io GitOps repo.
git_token = "forgejo_pat_..."

# Age private key mounted into the Argo CD repo-server for ksops/SOPS decryption.
sops_age_private_key = "AGE-SECRET-KEY-1..."
