# Example structure for SOPS-encrypted secrets (placeholders only).
# Setup:
#   1. cp secrets.enc.yaml.example secrets.yaml
#   2. Edit secrets.yaml with real values
#   3. just secrets-encrypt   (runs: sops -e secrets.yaml > secrets.enc.yaml)
#   4. rm secrets.yaml
#   5. export SOPS_AGE_KEY_FILE=~/.config/sops/age/keys.txt
#   6. tofu plan   (reads secrets.enc.yaml via carlpett/sops provider)
#
# When secrets.enc.yaml exists, secrets.auto.tfvars is optional for these keys.

proxmox_api_token: "user@pam!tokenid=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
git_token: "forgejo_pat_..."
sops_age_private_key: "AGE-SECRET-KEY-1..."
